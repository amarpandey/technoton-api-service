# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── SSL / TLS (Let's Encrypt) ────────────────────────────────────────────────
SSL_KEY=/etc/letsencrypt/live/api.technoton.co.in/privkey.pem
SSL_CERT=/etc/letsencrypt/live/api.technoton.co.in/fullchain.pem
SSL_CA=/etc/letsencrypt/live/api.technoton.co.in/chain.pem

# ─── Wialon ───────────────────────────────────────────────────────────────────
WIALON_API_URL=https://hst-api.wialon.com/wialon/ajax.html
